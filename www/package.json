{
  "name": "bun-react-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "twbuild": "bun x @tailwindcss/cli -i styles/globals.css -o src/output.css",
    "twwatch": "bun twbuild --watch",
    "dev": "bun --hot src/index.ts & bun twwatch",
    "start": "NODE_ENV=production bun src/index.ts & bun twwatch",
    "build": "bun run build.ts & bun twbuild"
  },
  "dependencies": {
    "2d-geometry": "^3.0.0",
    "@fontsource/poppins": "^5.2.7",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tailwindcss/cli": "^4.2.2",
    "@webgpu/types": "^0.1.69",
    "bun-plugin-tailwind": "^0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "evt": "^2.5.9",
    "lucide-react": "^0.545.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.3.1",
    "wasm-pong-but-better": "file:../pkg"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/bun": "latest",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0"
  }
}
